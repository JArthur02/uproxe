<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:virtualization="http://schemas.microsoft.com/appx/manifest/virtualization/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap virtualization rescap">

  <Identity
    Name="leekmadeek.uproxy"
    Publisher="CN=F60517ED-816A-4235-AB58-62B0A8BA554D"
    Version="2.0.0.1"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>uproxy</DisplayName>
    <PublisherDisplayName>leekmadeek</PublisherDisplayName>
    <Description>Scrape, check, classify, and export HTTP and SOCKS proxies.</Description>
    <Logo>Assets\StoreLogo.png</Logo>
    <!-- Windows 11 fine-grained exclusion: only the WinINET system-proxy key
         bypasses MSIX registry virtualization. All other HKCU writes remain
         virtualized and removable with the package. -->
    <virtualization:RegistryWriteVirtualization>
      <virtualization:ExcludedKeys>
        <virtualization:ExcludedKey>HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Internet Settings</virtualization:ExcludedKey>
      </virtualization:ExcludedKeys>
    </virtualization:RegistryWriteVirtualization>
  </Properties>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Dependencies>
    <TargetDeviceFamily
      Name="Windows.Desktop"
      MinVersion="10.0.22000.0"
      MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Applications>
    <Application
      Id="uproxy"
      Executable="uproxy.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="uproxy"
        Description="μProxy Tool — Windows proxy scraper and checker"
        BackgroundColor="#003764"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
    <rescap:Capability Name="unvirtualizedResources" />
  </Capabilities>
</Package>
